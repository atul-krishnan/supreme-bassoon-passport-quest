# App environment
APP_ENV=local

# Mobile API + Supabase
# Local defaults target Supabase CLI on your Mac.
# Android emulator maps localhost automatically to 10.0.2.2 at runtime.
# Physical devices cannot access localhost; use staging/prod URLs instead.
API_BASE_URL=http://127.0.0.1:54321/functions/v1/v1
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_PUBLISHABLE_KEY=replace_with_publishable_or_anon_key
GOOGLE_MAPS_API_KEY=
# Prefer Android-specific key to avoid package/SHA mismatch with iOS/web keys.
GOOGLE_MAPS_ANDROID_API_KEY=

# Observability
POSTHOG_HOST=
POSTHOG_API_KEY=
SENTRY_DSN=

# Release metadata
RELEASE_SHA=
EAS_PROJECT_ID=
PRODUCTION_SUPABASE_PROJECT_REF=mddunwxatxalpxcccxaf
